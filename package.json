{
  "name": "nuxt-starter-kit",
  "version": "1.0.0",
  "private": true,
  "description": "A comprehensive Nuxt.js 3 starter kit with TypeScript, Tailwind CSS, Shadcn-vue, i18n, and authentication",
  "author": "Nuxt Starter Kit",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "nuxt typecheck",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "prisma:generate": "pnpm prisma generate",
    "prisma:migrate:dev": "pnpm prisma migrate dev",
    "prisma:studio": "pnpm prisma studio",
    "prisma:db:seed": "pnpm prisma db seed"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.4.1",
    "@nuxtjs/color-mode": "^3.5.2",
    "@nuxtjs/i18n": "^9.5.5",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.1",
    "@prisma/nuxt": "^0.3.0",
    "@vueuse/core": "^13.3.0",
    "@vueuse/nuxt": "^13.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.0.11",
    "lucide-vue-next": "^0.513.0",
    "nuxt": "^3.17.5",
    "pinia": "^3.0.3",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.3.0",
    "shadcn-nuxt": "^2.2.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.5.0",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@prisma/client": "^6.9.0",
    "@types/node": "^22.15.29",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
